{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://developer.roku.com/schemas/direct-publisher-feed.json",
  "title": "Roku Direct Publisher Feed Schema",
  "description": "JSON Schema for validating Roku Direct Publisher content feeds",
  "type": "object",
  "required": ["providerName", "lastUpdated"],
  "properties": {
    "providerName": {
      "type": "string",
      "description": "Name of the content provider",
      "minLength": 1,
      "maxLength": 100
    },
    "language": {
      "type": "string",
      "description": "Primary language code (ISO 639-1)",
      "pattern": "^[a-z]{2}$"
    },
    "lastUpdated": {
      "type": "string",
      "description": "ISO 8601 timestamp of last feed update",
      "format": "date-time"
    },
    "movies": {
      "type": "array",
      "description": "List of movie content items",
      "items": {
        "$ref": "#/definitions/contentItem"
      }
    },
    "series": {
      "type": "array",
      "description": "List of series content items",
      "items": {
        "$ref": "#/definitions/contentItem"
      }
    },
    "shortFormVideos": {
      "type": "array",
      "description": "List of short-form video content items",
      "items": {
        "$ref": "#/definitions/contentItem"
      }
    },
    "totalCount": {
      "type": "integer",
      "description": "Total number of content items across all categories",
      "minimum": 0
    }
  },
  "definitions": {
    "contentItem": {
      "type": "object",
      "required": ["id", "title", "content"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique content identifier",
          "minLength": 1,
          "maxLength": 100
        },
        "title": {
          "type": "string",
          "description": "Content title",
          "minLength": 1,
          "maxLength": 255
        },
        "longDescription": {
          "type": "string",
          "description": "Detailed content description",
          "maxLength": 2000
        },
        "shortDescription": {
          "type": "string",
          "description": "Brief content description",
          "maxLength": 200
        },
        "thumbnail": {
          "type": "string",
          "description": "URL to content thumbnail image",
          "format": "uri"
        },
        "releaseDate": {
          "type": "string",
          "description": "Content release date (ISO 8601)",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "genres": {
          "type": "array",
          "description": "List of genre tags",
          "items": {
            "type": "string"
          }
        },
        "rating": {
          "type": "object",
          "properties": {
            "rating": {
              "type": "string",
              "description": "Content rating (e.g., PG, PG-13, R)"
            },
            "ratingSource": {
              "type": "string",
              "description": "Rating system source (e.g., MPAA, TV)"
            }
          }
        },
        "content": {
          "type": "object",
          "required": ["videos"],
          "properties": {
            "dateAdded": {
              "type": "string",
              "description": "Date content was added (ISO 8601)",
              "format": "date-time"
            },
            "videos": {
              "type": "array",
              "description": "List of video streams",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": ["url"],
                "properties": {
                  "url": {
                    "type": "string",
                    "description": "Video stream URL",
                    "format": "uri"
                  },
                  "quality": {
                    "type": "string",
                    "description": "Video quality (e.g., HD, SD, FHD)",
                    "enum": ["SD", "HD", "FHD", "UHD"]
                  },
                  "videoType": {
                    "type": "string",
                    "description": "Video format (e.g., MP4, HLS, DASH)"
                  }
                }
              }
            },
            "duration": {
              "type": "integer",
              "description": "Content duration in seconds",
              "minimum": 0
            },
            "language": {
              "type": "string",
              "description": "Audio language code",
              "pattern": "^[a-z]{2}$"
            }
          }
        }
      }
    }
  }
}
